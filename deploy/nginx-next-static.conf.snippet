# Next.js hashed assets — serve from standalone deploy path (before location / proxy).
# Path must match ecosystem.config.cjs cwd:
#   /var/www/pump/tma/apps/web/.next/standalone/apps/web
location /_next/static/ {
    alias /var/www/pump/tma/apps/web/.next/standalone/apps/web/.next/static/;
    expires 365d;
    add_header Cache-Control "public, max-age=31536000, immutable";
    access_log off;
    try_files $uri =404;
}
