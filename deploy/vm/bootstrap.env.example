# Pump production VM — one-time bootstrap config
# Copy to bootstrap.env (gitignored), fill secrets, run bootstrap-production.sh
#
#   cp deploy/vm/bootstrap.env.example deploy/vm/bootstrap.env
#   nano deploy/vm/bootstrap.env
#   bash deploy/vm/bootstrap-production.sh --confirm

# --- Domain & TLS (Cloudflare Origin Certificate) ---
PUMP_DOMAIN=spaceship.zugchain.org
# PEM file on VM: cert + private key blocks (same format as local cloudflare.txt)
CF_ORIGIN_FILE=/root/cloudflare.txt

# --- Paths ---
REPO_ROOT=/var/www/pump/tma
GIT_REPO_URL=https://github.com/webapp342/pump.git
GIT_REF=main

# SSH (provider panel + this port must match GitHub VM_SSH_PORT)
BOOTSTRAP_SSH_PORT=22022

# --- DB passwords (leave empty → auto-generated, saved to /root/pump-bootstrap-secrets.txt) ---
# PUMP_APP_DB_PASSWORD=
# PUMP_INDEXER_DB_PASSWORD=

# --- Restore from old VM backup (optional) ---
# If set and file exists, copied over generated .env (after DB URLs are patched)
# OLD_TMA_ENV=/root/backup/tma.env
# OLD_INDEXER_ENV=/root/backup/indexer.env

# --- Required secrets (bootstrap writes placeholders if empty — fill before first deploy) ---
ALCHEMY_RPC_KEY=
AUTH_SESSION_SECRET=
WALLET_ENCRYPTION_SECRET=
AIRDROP_KEEPER_PRIVATE_KEY=

# --- Public URLs (used in .env NEXT_PUBLIC_*) ---
NEXT_PUBLIC_APP_URL=https://spaceship.zugchain.org
NEXT_PUBLIC_WS_URL=wss://spaceship.zugchain.org/ws
NEXT_PUBLIC_CHAIN_ID=84532

# --- Indexer (auto on bootstrap: head minus N blocks — NOT .env.example 43317244) ---
INDEXER_HEAD_OFFSET=1000
# SKIP_INDEXER_HEAD_SEED=0

# --- Alto bundler (SCW token create / trade — EntryPoint 0.7) ---
# Fund executor with Base Sepolia ETH before bootstrap (or right after).
# Uses ALCHEMY_RPC_KEY for chain RPC if BUNDLER_CHAIN_RPC_URL unset.
BUNDLER_EXECUTOR_PRIVATE_KEYS=0x...
BUNDLER_UTILITY_PRIVATE_KEY=0x...
# BUNDLER_CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/KEY
# BUNDLER_RELAYER_PRIVATE_KEY=0x...   # legacy alias for executor
# SKIP_ALTO_BUNDLER=0
# BUNDLER_RPC_PORT=4337

# --- Optional: skip first npm build (infra only) ---
# SKIP_FIRST_DEPLOY=0
