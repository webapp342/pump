# =============================================================================
# pump-tma — LOCAL (Next.js UI, Base Sepolia)
# cp .env.example .env
# =============================================================================

NODE_ENV=development
PORT=3012
NEXT_PUBLIC_APP_URL=http://localhost:3012

DATABASE_URL=postgres://pump_app:CHANGE_ME@127.0.0.1:15432/pump_db
LAUNCHPAD_DATABASE_URL=postgres://pump_app:CHANGE_ME@127.0.0.1:15432/pump_db
VM1_MAIN_DB_URL=postgres://pump_app:CHANGE_ME@127.0.0.1:15432/pump_db

# Base Sepolia (chain 84532)
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Telegram OIDC login (2026) — @BotFather → Bot Settings → Web Login
# Allowed URLs must include site origin + /api/auth/telegram/callback
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_TELEGRAM_OIDC_CLIENT_ID=1234567890
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_OIDC_CLIENT_SECRET=CHANGE_ME
# Legacy /setdomain still recommended for fallback redirect widget host binding
AUTH_SESSION_SECRET=CHANGE_ME_USE_32_PLUS_CHAR_RANDOM_STRING

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME

# Apple Sign In — Services ID + Sign in with Apple key (.p8)
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/apple/callback
NEXT_PUBLIC_APPLE_OAUTH_CLIENT_ID=CHANGE_ME
APPLE_TEAM_ID=CHANGE_ME
APPLE_KEY_ID=CHANGE_ME
# PEM contents; use literal \n for newlines in .env
APPLE_PRIVATE_KEY=CHANGE_ME

# Admin console SIWE session TTL (seconds, default 86400 = 24h)
# ADMIN_SESSION_MAX_AGE_SEC=86400
WALLET_ENCRYPTION_SECRET=CHANGE_ME_USE_32_PLUS_CHAR_RANDOM_STRING

# Pimlico bundler (EntryPoint 0.7 / Kernel) — self-host Alto, NOT SaaS
# https://dashboard.pimlico.io/ only if you need a key for PAYG chain RPC elsewhere
# Client uses same-origin /api/bundler/rpc proxy by default
BUNDLER_RPC_URL=http://127.0.0.1:4337/rpc
# --- Fast buy/sell (Base Flashblocks only — chain 84532 or 8453) ---
# General reads (balance, arena, SSR) — any RPC:
# NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# Trade HTTPS — UserOp simulate/prepare + HTTP receipt fallback (buy/sell only):
# NEXT_PUBLIC_TRADE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# Trade WSS — Flashblocks newHeads ~200ms (buy/sell confirm; set explicitly):
# NEXT_PUBLIC_TRADE_WSS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# Disable fast trade path: NEXT_PUBLIC_FLASHBLOCKS_ENABLED=0
# Buy/sell step-by-step timing in browser console (build-time):
# NEXT_PUBLIC_TRADE_TIMING=1
# Alto VM setup (see deploy/bundler/alto/setup-alto-pm2.sh):
# BUNDLER_CHAIN_ID=84532
# BUNDLER_CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/PAYG_KEY
# Alto Base Sepolia tuning (optional — setup-alto-pm2.sh defaults):
# ALTO_BLOCK_TIME_MS=2000
# ALTO_MAX_BUNDLE_INTERVAL_MS=400
# ALTO_CHAIN_TYPE=op-stack
# BUNDLER_EXECUTOR_PRIVATE_KEYS=0x...,0x...
# BUNDLER_UTILITY_PRIVATE_KEY=0x...
# Optional client path override:
# NEXT_PUBLIC_BUNDLER_RPC_URL=/api/bundler/rpc
# Verbose bundler RPC logs (dev enables automatically)
# NEXT_PUBLIC_BUNDLER_DEBUG=1
# BUNDLER_DEBUG=1

# Legacy Skandha (deprecated — use Alto)
# deploy/bundler/setup-skandha-pm2.sh
# BUNDLER_RELAYER_PRIVATE_KEY=0x...

# Contracts — contracts/deployments/base-sepolia-*.json (Admin wipe syncs contract_registry from these)
NEXT_PUBLIC_MEME_FACTORY=0xaA3AC8559417D1101FfF43cF4fDdF50279C2e594
NEXT_PUBLIC_BONDING_CURVE_MANAGER=0x0f8b0052F7750e6d481DBb447FD4b7b45ac3b615
NEXT_PUBLIC_AIRDROP_MANAGER=0x91E499D95835915b54e12e82df04167D52F17A49

# Token logos (Cloudflare R2)
NEXT_PUBLIC_ASSETS_CDN=https://your-cdn.example.com
NEXT_PUBLIC_ASSETS_CACHE_BUST=v=1
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=zugswap-assets

# Private key YOK — kullanıcı Telegram + Kernel SCW ile giriş yapar. Indexer/keeper VM'de çalışır (README.md).

# --- Performance flags (production defaults ON unless set to false) ---
# USE_BONDING_STATE_COUNTS=false
# USE_MV_TOKEN_STATS=false
# USE_TOKEN_BOARD_STATS=true      # phase 3 — read token_board_stats (indexer-maintained)
# USE_REDIS_ARENA_CACHE=true      # phase 3 — Redis hot cache for arena API/SSR
# REDIS_URL=redis://127.0.0.1:6379
# MV_REFRESH_ENABLED=true         # indexer — MV reconcile + price anchors
# INCREMENTAL_BOARD_STATS=true    # indexer — upsert token_board_stats on trade
# NEXT_PUBLIC_WS_ENABLED=true
# NEXT_PUBLIC_WS_URL=wss://pump.zugchain.org/ws

# NEXT_PUBLIC_LOCAL_FIRST_READS=true

# --- Tier 3 scale (production VM) ---
# LAUNCHPAD_DATABASE_READ_URL=postgres://pump_app:PASS@127.0.0.1:6432/pump_db
# PGBOUNCER_ENABLED=true
# PG_POOL_MAX=4

# --- Admin env editor (VM only; auto-detected from standalone cwd if unset) ---
# PUMP_REPO_ROOT=/var/www/pump/tma
# PUMP_INDEXER_ENV_PATH=/var/www/pump/Indexer/.env
