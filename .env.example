# =============================================================================
# zugchain-pump-tma — LOCAL ONLY (Next.js UI) 
# cp .env.example .env
# =============================================================================
# DB tunnel (ayrı terminal):
#   ssh -p 22022 -L 15432:127.0.0.1:5432 root@104.207.64.115
# =============================================================================

NODE_ENV=development
PORT=3012
NEXT_PUBLIC_APP_URL=http://localhost:3012

# Database (VM pump_db via SSH tunnel)
DATABASE_URL=postgres://pump_app:CHANGE_ME@127.0.0.1:15432/pump_db
LAUNCHPAD_DATABASE_URL=postgres://pump_app:CHANGE_ME@127.0.0.1:15432/pump_db
VM1_MAIN_DB_URL=postgres://pump_app:CHANGE_ME@127.0.0.1:15432/pump_db

# BSC Testnet (chain 97)
NEXT_PUBLIC_CHAIN_ID=97
# Avoid publicnode for AA — eth_getLogs returns 403/limit errors on free RPCs
# Alchemy BSC testnet (recommended for Skandha receipt lookup + client reads):
NEXT_PUBLIC_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
NEXT_PUBLIC_ZUGCHAIN_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Account Abstraction (Kernel SCW + Telegram login — no paymaster; users pay gas from SCW BNB)
# Telegram Login Widget: create bot via @BotFather, /setdomain → pump.local (local) or prod domain
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_TOKEN=CHANGE_ME
AUTH_SESSION_SECRET=CHANGE_ME_USE_32_PLUS_CHAR_RANDOM_STRING
WALLET_ENCRYPTION_SECRET=CHANGE_ME_USE_32_PLUS_CHAR_RANDOM_STRING

# Pimlico bundler (EntryPoint 0.7 / Kernel) — self-host Alto, NOT SaaS
# https://dashboard.pimlico.io/ only if you need a key for PAYG chain RPC elsewhere
# Client uses same-origin /api/bundler/rpc proxy by default
BUNDLER_RPC_URL=http://127.0.0.1:4337/rpc
# Alto VM setup (see deploy/bundler/alto/setup-alto-pm2.sh):
# BUNDLER_CHAIN_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/PAYG_KEY
# BUNDLER_EXECUTOR_PRIVATE_KEYS=0x...,0x...
# BUNDLER_UTILITY_PRIVATE_KEY=0x...
# Optional client path override:
# NEXT_PUBLIC_BUNDLER_RPC_URL=/api/bundler/rpc
# Verbose bundler RPC logs (dev enables automatically)
# NEXT_PUBLIC_BUNDLER_DEBUG=1
# BUNDLER_DEBUG=1

# Legacy Skandha (deprecated — use Alto)
# deploy/bundler/setup-skandha-pm2.sh
# BUNDLER_RELAYER_PRIVATE_KEY=0x...

# Contracts (deployments/bsc-testnet-*.json)
NEXT_PUBLIC_MEME_FACTORY=0x2Fa07dFd25f1C2F3E2C0b6084bc5e0b87c9997A2
NEXT_PUBLIC_BONDING_CURVE_MANAGER=0xd59D34e98f1437507fb45D6960BF8d06EB986B33
NEXT_PUBLIC_AIRDROP_MANAGER=0xA943566a158355504f089e37062145c0f67D1d2a
NEXT_PUBLIC_ADMIN_ADDRESS=0x11Ea71d1BEb04Aece4d06a585D9dbc6F58836880

# Token logos (Cloudflare R2)
NEXT_PUBLIC_ASSETS_CDN=https://cdn.zugchain.org
NEXT_PUBLIC_ASSETS_CACHE_BUST=v=1
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=zugswap-assets

# Private key YOK — kullanıcı Telegram + Kernel SCW ile giriş yapar. Indexer/keeper VM'de çalışır (README.md).

# --- Performance flags (production defaults ON unless set to false) ---
# USE_BONDING_STATE_COUNTS=false
# USE_MV_TOKEN_STATS=false
# USE_TOKEN_BOARD_STATS=true      # phase 3 — read token_board_stats (indexer-maintained)
# USE_REDIS_ARENA_CACHE=true      # phase 3 — Redis hot cache for arena API/SSR
# REDIS_URL=redis://127.0.0.1:6379
# MV_REFRESH_ENABLED=true         # indexer — MV reconcile + price anchors
# INCREMENTAL_BOARD_STATS=true    # indexer — upsert token_board_stats on trade
# NEXT_PUBLIC_WS_ENABLED=true
# NEXT_PUBLIC_WS_URL=wss://pump.zugchain.org/ws

# NEXT_PUBLIC_LOCAL_FIRST_READS=true

# --- Tier 3 scale (production VM) ---
# LAUNCHPAD_DATABASE_READ_URL=postgres://pump_app:PASS@127.0.0.1:6432/pump_db
# PGBOUNCER_ENABLED=true
# PG_POOL_MAX=4
