{
  "name": "@pump/solana-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Solana cluster config, PDA seeds, and program ID placeholders for Pump",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.8.2"
  }
}
