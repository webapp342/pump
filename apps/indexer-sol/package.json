{
  "name": "@pump/indexer-sol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build -w @pump/solana-sdk",
    "build": "tsc -p tsconfig.json",
    "indexer": "node dist/indexer.js",
    "indexer:dev": "tsx src/indexer.ts",
    "backfill-cost-basis": "tsx src/backfill-cost-basis.ts",
    "check-position-invariants": "tsx src/check-position-invariants.ts",
    "check-chart-parity": "tsx src/check-chart-parity.ts",
    "backfill-clickhouse-trades": "tsx src/backfill-clickhouse-trades.ts",
    "test:decode": "tsx src/decode.selftest.ts",
    "test:position-cost": "tsx src/position-cost.selftest.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pump/solana-sdk": "*",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
