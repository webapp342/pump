# Pump Solana indexer — copy to /var/www/pump/tma/apps/indexer-sol/.env on VM
LAUNCHPAD_DATABASE_URL=postgres://pump_indexer:CHANGE_ME@127.0.0.1:5432/pump_db

SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_CHAIN_ID=901103

SOLANA_FACTORY_PROGRAM_ID=Hwv85kSodkR34rBTE1J67aSzixnAkXdAX6HzZnKDCvus
SOLANA_CURVE_PROGRAM_ID=Hwv85kSodkR34rBTE1J67aSzixnAkXdAX6HzZnKDCvus
SOLANA_TREASURY_PROGRAM_ID=Hwv85kSodkR34rBTE1J67aSzixnAkXdAX6HzZnKDCvus

SOLANA_INDEXER_SOURCE=rpc
SOLANA_INDEXER_POLL_MS=2000
SOLANA_INDEXER_START_SLOT=0

INCREMENTAL_BOARD_STATS=true
INCREMENTAL_CANDLES=true

# Realtime board / portfolio WS (required for live UX)
REDIS_PUBLISH_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

# Self-hosted ClickHouse OLAP (enable via deploy/vm/enable-clickhouse.sh)
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DUAL_WRITE=true
CLICKHOUSE_DATABASE=pump

