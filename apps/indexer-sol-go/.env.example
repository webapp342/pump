# F5 — Go indexer (LaserStream gRPC only — no RPC poll/WS)
GO_SHADOW_MODE=read_only
SOLANA_CLUSTER=devnet
SOLANA_INDEXER_SOURCE=laserstream

# Helius LaserStream devnet (VM: same region as server when possible)
SOLANA_GEYSER_ENDPOINT=https://laserstream-devnet-ewr.helius-rpc.com
HELIUS_API_KEY=

# Launchpad program(s) — comma-separated; deduped; single tx filter (quota-friendly)
SOLANA_GEYSER_PROGRAM_IDS=Hwv85kSodkR34rBTE1J67aSzixnAkXdAX6HzZnKDCvus

# Metrics heartbeat only (not ingest interval)
SOLANA_INDEXER_POLL_MS=5000

# F5c primary writes (later)
# REDIS_URL=redis://127.0.0.1:6379
# LAUNCHPAD_DATABASE_URL=
