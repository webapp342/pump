# =============================================================================
# Indexer + Airdrop Keeper — VM ONLY
# =============================================================================
# VM path:  /var/www/pump/Indexer/.env
# Kurulum:  cp .env.example .env  &&  nano .env
#
# Bu dosya hem pump-indexer hem pump-airdrop-keeper tarafından okunur
# (systemd EnvironmentFile aynı path).
# =============================================================================

# --- PostgreSQL (production: PgBouncer 6432; migrations/admin: direct 5432) ---
LAUNCHPAD_DATABASE_URL=postgres://pump_indexer:CHANGE_ME@127.0.0.1:6432/pump_db
# Mission puanları için ZORUNLU — tek DB kurulumunda aynı URL
VM1_MAIN_DB_URL=postgres://pump_indexer:CHANGE_ME@127.0.0.1:6432/pump_db
PGBOUNCER_ENABLED=true
PG_POOL_MAX=4

# --- BSC Testnet RPC (virgülle yedek URL önerilir) ---
BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com,https://bsc-testnet.public.blastapi.io
ZUGCHAIN_CHAIN_ID=97

# --- Indexer ---
INDEXER_START_BLOCK=112408852
INDEXER_CONFIRMATIONS=1
INDEXER_CHUNK_SIZE=200
INDEXER_POLL_INTERVAL_MS=2000
INDEXER_STATE_KEY=pump_bsc_indexer
# INDEXER_ONCE=true   # tek seferlik catch-up (systemd'de kullanma)

# Foundry build çıktısı — VM Linux yolu (Windows yolu YAZMA)
CONTRACT_ARTIFACTS_DIR=/var/www/pump/contracts/out

# contract_registry yoksa fallback (genelde DB'den okunur)
PUMP_AIRDROP_MANAGER=0xA943566a158355504f089e37062145c0f67D1d2a

# --- Airdrop keeper (pump-airdrop-keeper.service) ---
AIRDROP_KEEPER_PRIVATE_KEY=0xCHANGE_ME_64_HEX_CHARS
AIRDROP_KEEPER_POLL_MS=60000
# AIRDROP_KEEPER_ONCE=true

# --- Performance (production ON) ---
MV_REFRESH_ENABLED=true
INCREMENTAL_BOARD_STATS=true
# Chart candles — must be true in production (default follows INCREMENTAL_BOARD_STATS)
INCREMENTAL_CANDLES=true
# WS broadcast intervals (all 6 still written to token_candles)
CANDLE_WS_INTERVALS=1m,5m
MV_RECONCILE_DEBOUNCE_MS=60000
REDIS_URL=redis://127.0.0.1:6379
REDIS_PUBLISH_ENABLED=true
REDIS_CACHE_ENABLED=true

# --- Tier 3: watchBlocks (requires BSC_WS_URL) ---
INDEXER_USE_WS_BLOCKS=true
BSC_WS_URL=wss://bsc-testnet-rpc.publicnode.com
