# =============================================================================
# Indexer + Airdrop Keeper — VM ONLY (Base Sepolia)
# =============================================================================

# --- PostgreSQL ---
LAUNCHPAD_DATABASE_URL=postgres://pump_indexer:CHANGE_ME@127.0.0.1:6432/pump_db
VM1_MAIN_DB_URL=postgres://pump_indexer:CHANGE_ME@127.0.0.1:6432/pump_db
PGBOUNCER_ENABLED=true
PG_POOL_MAX=4

# --- Base Sepolia RPC ---
CHAIN_ID=84532
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY,https://sepolia.base.org
WS_RPC_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# --- Indexer ---
# deploymentBlock from base-sepolia-launchpad.json minus 1
INDEXER_START_BLOCK=43317244
INDEXER_CONFIRMATIONS=2
INDEXER_CHUNK_SIZE=500
# Alchemy free tier: max 10 blocks per eth_getLogs — indexer auto-splits ranges; use 10 to reduce retries
# INDEXER_CHUNK_SIZE=10
INDEXER_POLL_INTERVAL_MS=2000
INDEXER_STATE_KEY=launchpad_indexer

CONTRACT_ARTIFACTS_DIR=/var/www/pump/contracts/out

# Fallback if contract_registry row missing (normally DB registry is source of truth)
PUMP_AIRDROP_MANAGER=0x91E499D95835915b54e12e82df04167D52F17A49
MEME_FACTORY=0xaA3AC8559417D1101FfF43cF4fDdF50279C2e594
BONDING_CURVE_MANAGER=0x0f8b0052F7750e6d481DBb447FD4b7b45ac3b615

BONDING_VIRTUAL_ETH_RESERVE_WEI=5000000000000000000

# --- Airdrop keeper ---
AIRDROP_KEEPER_PRIVATE_KEY=0xCHANGE_ME_64_HEX_CHARS
AIRDROP_KEEPER_POLL_MS=60000

# --- Performance ---
MV_REFRESH_ENABLED=true
INCREMENTAL_BOARD_STATS=true
INCREMENTAL_CANDLES=true
CANDLE_WS_INTERVALS=5m
REDIS_URL=redis://127.0.0.1:6379
REDIS_PUBLISH_ENABLED=true
REDIS_CACHE_ENABLED=true
INDEXER_USE_WS_BLOCKS=true

# --- Web Push (trade alerts from indexer) ---
# Same VAPID keys as apps/web/.env
# PUSH_TRADE_ALERTS_ENABLED=true
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=CHANGE_ME
# VAPID_PRIVATE_KEY=CHANGE_ME
# VAPID_SUBJECT=https://your-production-domain
# NATIVE_SYMBOL=ETH
