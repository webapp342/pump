    "airdrop-keeper": "node dist/airdrop-keeper.js",
    "airdrop-keeper:dev": "tsx src/airdrop-keeper.ts",
    "sync-king": "tsx src/sync-king.ts",
    "sync-missions": "tsx src/sync-missions.ts",
    "backfill-cost-basis": "tsx src/backfill-cost-basis.ts",
    "backfill-spot-price": "tsx src/backfill-spot-price.ts",
    "backfill-board-stats": "tsx src/backfill-board-stats.ts",
    "backfill-candles": "tsx src/backfill-candles.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "viem": "^2.43.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
